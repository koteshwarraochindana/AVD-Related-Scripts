# --- CONFIGURATION AREA ---
$subscriptionName = "Your Subscription Name or ID"  # Enter your Sub Name or ID
$rgName           = "YourResourceGroupName"         # Enter your Resource Group Name
$csvPath          = "C:\path\to\your\hostnames.csv" # Path to your input CSV
$outputPath       = "C:\path\to\VM_Report.csv"      # Path for the results CSV
# --------------------------

# 1. AUTHENTICATION: Check if connected; if not, prompt for login
$context = Get-AzContext
if (!$context) {
    Write-Host "No active Azure session. Please log in..." -ForegroundColor Yellow
    Connect-AzAccount
}

# 2. CONTEXT: Set the specific subscription
Write-Host "Setting context to: $subscriptionName" -ForegroundColor Cyan
Select-AzSubscription -Subscription $subscriptionName | Out-Null

# 3. IMPORT: Load VM names from CSV (Header must be 'VMName')
if (!(Test-Path $csvPath)) {
    Write-Error "CSV file not found at $csvPath. Please check the path."
    return
}
$vmsToProcess = Import-Csv -Path $csvPath

# 4. PROCESSING: Loop through each VM
$results = foreach ($item in $vmsToProcess) {
    $currentVM = $item.VMName
    Write-Host "Processing: $currentVM..." -ForegroundColor White
    
    try {
        # Get the VM object
        $vm = Get-AzVM -ResourceGroupName $rgName -Name $currentVM -ErrorAction Stop
        
        # Get the OS Disk metadata (the creation date source)
        $osDiskName = $vm.StorageProfile.OsDisk.Name
        $disk = Get-AzDisk -ResourceGroupName $rgName -DiskName $osDiskName
        
        [PSCustomObject]@{
            VMName        = $currentVM
            ResourceGroup = $rgName
            CreationDate  = $disk.TimeCreated
            Status        = "Success"
        }
    }
    catch {
        [PSCustomObject]@{
            VMName        = $currentVM
            ResourceGroup = $rgName
            CreationDate  = "N/A"
            Status        = "Error: $($_.Exception.Message)"
        }
    }
}

# 5. EXPORT: Save to CSV
$results | Export-Csv -Path $outputPath -NoTypeInformation
Write-Host "`nFinished! Report generated at: $outputPath" -ForegroundColor Green
