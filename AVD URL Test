# ==============================================================================
# SCRIPT: Bulk Power-On or Restart Session Hosts (No Tags Applied)
# PREREQUISITES: A CSV with headers: VMName, ResourceGroupName, SubscriptionId
# ==============================================================================

# 1. Update this path to the location of your target CSV file
$CSVPath = "C:\temp\targets.csv"

# Verify the CSV exists before running
if (-not (Test-Path -Path $CSVPath)) {
    Write-Error "CRITICAL: The CSV file could not be found at $CSVPath."
    return
}

# 2. Import the CSV data rows
$TargetVMs = Import-Csv -Path $CSVPath

Write-Host "==================================================================" -ForegroundColor Cyan
Write-Host " [START] Powering On / Restarting $($TargetVMs.Count) VMs" -ForegroundColor Cyan
Write-Host "==================================================================" -ForegroundColor Cyan

# Track loop counters
$SuccessCount = 0
$FailureCount = 0

# 3. Sequential Execution Loop
foreach ($Row in $TargetVMs) {
    $VMName = $Row.VMName
    $RGName = $Row.ResourceGroupName
    $SubId  = $Row.SubscriptionId
    
    Write-Host "------------------------------------------------------------------" -ForegroundColor Gray
    Write-Host "Targeting Host: $VMName" -ForegroundColor Yellow

    # Catch empty or malformed rows instantly
    if ([string]::IsNullOrWhiteSpace($VMName) -or [string]::IsNullOrWhiteSpace($RGName) -or [string]::IsNullOrWhiteSpace($SubId)) {
        Write-Host "[SKIP] Row has missing values. Check your CSV layout." -ForegroundColor Cyan
        $FailureCount++
        continue
    }

    try {
        # STEP A: Switch Azure Context immediately to the current VM's subscription
        Set-AzContext -SubscriptionId $SubId | Out-Null
        
        # STEP B: Check the live power state of the VM
        $VMStatus = Get-AzVM -ResourceGroupName $RGName -Name $VMName -Status -ErrorAction Stop
        $PowerState = ($VMStatus.Statuses | Where-Object Code -like "PowerState/*").Code
        
        # STEP C: Evaluate state and take action
        if ($PowerState -eq "PowerState/running") {
            # VM is already on -> Restart it
            Restart-AzVM -ResourceGroupName $RGName -Name $VMName -NoWait -ErrorAction Stop | Out-Null
            Write-Host "[SUCCESS] Host is active. Graceful restart signal dispatched." -ForegroundColor Green
        }
        else {
            # VM is stopped/deallocated -> Power it on
            Start-AzVM -ResourceGroupName $RGName -Name $VMName -NoWait -ErrorAction Stop | Out-Null
            Write-Host "[SUCCESS] Host is down. Power-on signal dispatched." -ForegroundColor Green
        }
        
        $SuccessCount++
    } 
    catch {
        Write-Host "[FAILURE] Could not execute commands for host $VMName." -ForegroundColor Red
        Write-Host "REASON: $_" -ForegroundColor Red
        $FailureCount++
    }
}

# Determine reporting color safely using PS 5.1 compatible standard IF block
$FinalColor = "Green"
if ($FailureCount -gt 0) { $FinalColor = "Red" }

# 4. Final Run Execution Summary Report
Write-Host "==================================================================" -ForegroundColor Cyan
Write-Host " [FINISHED] Automated Workflow Completed!" -ForegroundColor Cyan
Write-Host " Successful Executions: $SuccessCount" -ForegroundColor Green
Write-Host " Failed/Skipped Rows:   $FailureCount" -ForegroundColor $FinalColor
Write-Host "==================================================================" -ForegroundColor Cyan
