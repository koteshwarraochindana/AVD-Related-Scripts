# ===========================
# MODULES & AUTH
# ===========================
if (-not (Get-Module -ListAvailable -Name "Az.DesktopVirtualization")) {
    Install-Module -Name "Az.DesktopVirtualization" -Scope CurrentUser -Force
}
Import-Module "Az.DesktopVirtualization"

Write-Host "Connecting to Azure..." -ForegroundColor Cyan
try {
    $null = Connect-AzAccount -WarningAction SilentlyContinue -ErrorAction Stop
} catch {
    $null = Connect-AzAccount -DeviceCode -WarningAction SilentlyContinue
}

# ===========================
# GET ALL SUBSCRIPTIONS
# ===========================
$subscriptions = Get-AzSubscription
Write-Host "Found $($subscriptions.Count) subscription(s)." -ForegroundColor Cyan

# ===========================
# DATA COLLECTION
# ===========================
$allSessionHosts = foreach ($sub in $subscriptions) {

    Write-Host "Switching to subscription: $($sub.Name) [$($sub.Id)]" -ForegroundColor Yellow
    $null = Set-AzContext -SubscriptionId $sub.Id -WarningAction SilentlyContinue

    $hostPools = Get-AzWvdHostPool -ErrorAction SilentlyContinue

    if (-not $hostPools) {
        Write-Host "  No host pools found in $($sub.Name). Skipping." -ForegroundColor Gray
        continue
    }

    foreach ($hp in $hostPools) {
        Write-Host "  Processing host pool: $($hp.Name)" -ForegroundColor Gray

        $hosts = Get-AzWvdSessionHost -HostPoolName $hp.Name -ResourceGroupName $hp.ResourceGroupName -ErrorAction SilentlyContinue

        if (-not $hosts) {
            Write-Host "    No session hosts found in $($hp.Name). Skipping." -ForegroundColor Gray
            continue
        }

        foreach ($sh in $hosts) {
            $vmName = $sh.ResourceId.Split('/')[-1]
            $vmRg   = $sh.ResourceId.Split('/')[4]

            $imagePublisher = $null
            $imageOffer     = $null
            $imageSku       = $null
            $imageVersion   = $null
            $imageId        = $null
            $imageType      = $null

            try {
                $vm     = Get-AzVM -ResourceGroupName $vmRg -Name $vmName -ErrorAction Stop
                $imgRef = $vm.StorageProfile.ImageReference

                if ($imgRef.Id) {
                    # Custom image or Shared Image Gallery (SIG)
                    $imageType = "Custom/SIG"
                    $imageId   = $imgRef.Id

                    if ($imgRef.Id -match '/versions/([^/]+)$') {
                        $imageVersion = $matches[1]
                    }
                    if ($imgRef.Id -match '/images/([^/]+)/versions') {
                        $imageOffer = $matches[1]
                    }
                    if ($imgRef.Id -match '/galleries/([^/]+)/images') {
                        $imagePublisher = $matches[1]
                    }

                } else {
                    # Marketplace image
                    $imageType      = "Marketplace"
                    $imagePublisher = $imgRef.Publisher
                    $imageOffer     = $imgRef.Offer
                    $imageSku       = $imgRef.Sku

                    if ($imgRef.ExactVersion) {
                        $imageVersion = $imgRef.ExactVersion
                    } else {
                        $imageVersion = $imgRef.Version
                    }
                }

            } catch {
                $imageType = "Error: $_"
            }

            [PSCustomObject]@{
                SubscriptionName = $sub.Name
                SubscriptionId   = $sub.Id
                HostPoolName     = $hp.Name
                SessionHostName  = $sh.Name.Split('/')[-1]
                VMName           = $vmName
                VMResourceGroup  = $vmRg
                Status           = $sh.Status
                AssignedUser     = $sh.AssignedUser
                LastHeartbeat    = $sh.LastHeartBeat
                UpdateState      = $sh.UpdateState
                ImageType        = $imageType
                ImagePublisher   = $imagePublisher
                ImageOffer       = $imageOffer
                ImageSku         = $imageSku
                ImageVersion     = $imageVersion
                ImageId          = $imageId
            }
        }
    }
}

# ===========================
# EXPORT TO CSV
# ===========================
$csvPath = "C:\Temp\AVD_SessionHosts_ImageReport.csv"

if ($allSessionHosts) {
    $allSessionHosts | Export-Csv -Path $csvPath -NoTypeInformation -Force
    $allSessionHosts | Format-Table SubscriptionName, HostPoolName, VMName, ImageType, ImagePublisher, ImageOffer, ImageSku, ImageVersion -AutoSize
    Write-Host "Success! Report exported to $csvPath" -ForegroundColor Green
} else {
    Write-Host "No session hosts found across any subscription." -ForegroundColor Yellow
}
