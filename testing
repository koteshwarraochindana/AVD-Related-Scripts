# 1. Start Connection
Connect-AzAccount -WarningAction SilentlyContinue

$ExportPath = "$home\Desktop\AVD-04.csv"
$FullReport = @()
$TotalHosts = 0; $TotalAssigned = 0; $TotalEmpty = 0

# 2. Global Scan across all Subscriptions
$Subs = Get-AzSubscription
foreach ($Sub in $Subs) {
    Write-Host "Scanning Subscription: $($Sub.Name)" -ForegroundColor Cyan
    $Context = Set-AzContext -SubscriptionId $Sub.Id -Force -ErrorAction SilentlyContinue
    if (-not $Context) { continue }
    
    $Workspaces = Get-AzWvdWorkspace -ErrorAction SilentlyContinue
    foreach ($WS in $Workspaces) {
        $WSRG = ($WS.Id -split '/')[4]
        
        $AppGroups = Get-AzWvdApplicationGroup -ResourceGroupName $WSRG -ErrorAction SilentlyContinue | Where-Object { $_.WorkspaceArmPath -eq $WS.Id }
        
        foreach ($AG in $AppGroups) {
            $PoolName = ($AG.HostPoolArmPath -split '/')[-1]
            $PoolRG = ($AG.Id -split '/')[4]
            
            $Pool = Get-AzWvdHostPool -ResourceGroupName $PoolRG -Name $PoolName -ErrorAction SilentlyContinue
            if (-not $Pool) { continue }

            # --- TARGETED FILTER: Only AD Groups assigned the User Role ---
            $Assignments = Get-AzRoleAssignment -Scope $AG.Id -ErrorAction SilentlyContinue | Where-Object { 
                $_.ObjectType -eq "Group" -and 
                $_.RoleDefinitionName -eq "Desktop Virtualization User"
            }
            
            $Entitlements = ($Assignments.DisplayName | Sort-Object -Unique | Where-Object { $_ }) -join "; "
            if ([string]::IsNullOrWhiteSpace($Entitlements)) { $Entitlements = "No Groups Assigned" }

            $SessionHosts = Get-AzWvdSessionHost -ResourceGroupName $PoolRG -HostPoolName $Pool.Name -ErrorAction SilentlyContinue
            
            $CountTotal = ($SessionHosts | Measure-Object).Count
            $CountAssigned = ($SessionHosts | Where-Object { -not [string]::IsNullOrWhiteSpace($_.AssignedUser) } | Measure-Object).Count
            $CountEmpty = $CountTotal - $CountAssigned
            $TotalHosts += $CountTotal; $TotalAssigned += $CountAssigned; $TotalEmpty += $CountEmpty

            $Location = $Pool.Location
            $NetInfo = "No VMs Found"
            
            if ($CountTotal -gt 0) {
                $FirstSH = $SessionHosts | Select-Object -First 1
                if ($FirstSH.ResourceId) {
                    $VMRG = ($FirstSH.ResourceId -split '/')[4]
                    $VMName = ($FirstSH.ResourceId -split '/')[-1]
                    
                    $VM = Get-AzVM -ResourceGroupName $VMRG -Name $VMName -ErrorAction SilentlyContinue
                    if ($VM) {
                        $Location = $VM.Location
                        $NIC = Get-AzNetworkInterface -ResourceId $VM.NetworkProfile.NetworkInterfaces.Id -ErrorAction SilentlyContinue
                        if ($NIC) {
                            $SubnetId = $NIC.IpConfigurations.Subnet.Id
                            $SubnetName = ($SubnetId -split '/')[-1]
                            $VNetName = ($SubnetId -split '/')[-3]
                            $NetInfo = "$VNetName / $SubnetName"
                        }
                    }
                }
            }

            $FullReport += [PSCustomObject]@{
                Subscription      = $Sub.Name
                Workspace         = $WS.Name
                HostPool          = $Pool.Name
                HostPoolType      = $Pool.HostPoolType
                Entitlements      = $Entitlements
                Location          = $Location
                "VNet Subnet"     = $NetInfo
                "Total Hosts"     = $CountTotal
                "Assigned VMs"    = $CountAssigned
                "Empty Assignment"= $CountEmpty
            }
        }
    }
}

# 3. Add Grand Total Row
$FullReport += [PSCustomObject]@{
    Subscription      = "--- GRAND TOTAL ---"
    Workspace         = ""
    HostPool          = ""
    HostPoolType      = ""
    Entitlements      = ""
    Location          = ""
    "VNet Subnet"     = ""
    "Total Hosts"     = $TotalHosts
    "Assigned VMs"    = $TotalAssigned
    "Empty Assignment"= $TotalEmpty
}

# 4. Export and Open
$FullReport | Export-Csv -Path $ExportPath -NoTypeInformation
Write-Host "`nReport saved to Desktop: $ExportPath" -ForegroundColor Green
Invoke-Item $ExportPath
