# ==========================
# Restart Azure VMs (CSV) - Parallel Execution (PowerShell 5)
# ==========================

$vmListFile = "C:\Temp\vm-list.csv"
$maxJobs = 50
$reportPath = "C:\Temp\vm-restart-report.csv"

# Validate file
if (-not (Test-Path $vmListFile)) {
    throw "CSV file not found at $vmListFile"
}

# Import CSV
$vmList = Import-Csv -Path $vmListFile

# Connect to Azure
Connect-AzAccount

# OPTIONAL
# Select-AzSubscription -SubscriptionId "your-subscription-id"

# Job script
$scriptBlock = {
    param($vmName, $rg)

    try {
        Import-Module Az.Compute -ErrorAction Stop

        Restart-AzVM -Name $vmName -ResourceGroupName $rg -ErrorAction Stop

        [PSCustomObject]@{
            VMName        = $vmName
            ResourceGroup = $rg
            Status        = "Success"
            Message       = "Restarted successfully"
        }
    }
    catch {
        [PSCustomObject]@{
            VMName        = $vmName
            ResourceGroup = $rg
            Status        = "Failed"
            Message       = $_.Exception.Message
        }
    }
}

$jobs = @()
$results = @()

Write-Host "Starting restart for $($vmList.Count) VMs with max $maxJobs parallel jobs..."

foreach ($vm in $vmList) {

    # Use correct column names
    $vmName = $vm.VMName
    $rg     = $vm.ResourceGroup

    # Safe validation (no IsNullOrWhiteSpace needed)
    if (-not $vmName -or -not $rg) {
        Write-Host "Skipping invalid row: $($vm | ConvertTo-Json -Compress)"
        continue
    }

    while ($jobs.Count -ge $maxJobs) {

        $finished = Wait-Job -Job $jobs -Any -Timeout 5

        if ($finished) {
            $output = Receive-Job -Job $finished

            foreach ($o in $output) {
                if ($o.Status -eq "Success") {
                    Write-Host "SUCCESS: $($o.VMName) ($($o.ResourceGroup)) - $($o.Message)"
                }
                else {
                    Write-Host "FAILED: $($o.VMName) ($($o.ResourceGroup)) - $($o.Message)"
                }

                $results += $o
            }

            Remove-Job -Job $finished -Force
            $jobs = $jobs | Where-Object { $_.State -eq 'Running' -or $_.State -eq 'NotStarted' }
        }
    }

    $jobs += Start-Job -ScriptBlock $scriptBlock -ArgumentList $vmName, $rg
}

Write-Host "Waiting for remaining jobs to finish..."

$jobs | Wait-Job | ForEach-Object {

    $output = Receive-Job -Job $_

    foreach ($o in $output) {
        if ($o.Status -eq "Success") {
            Write-Host "SUCCESS: $($o.VMName) ($($o.ResourceGroup)) - $($o.Message)"
        }
        else {
            Write-Host "FAILED: $($o.VMName) ($($o.ResourceGroup)) - $($o.Message)"
        }

        $results += $o
    }

    Remove-Job -Job $_ -Force
}

$results | Export-Csv -Path $reportPath -NoTypeInformation

Write-Host "Completed. Report saved to $reportPath"
