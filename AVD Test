# ==========================
# Restart Azure VMs from CSV
# PowerShell 5.1
# Testing Environment
# ==========================

$vmListFile = "C:\Temp\vm-list.csv"
$reportPath = "C:\Temp\vm-restart-report.csv"
$maxJobs = 20

if (!(Test-Path $vmListFile)) {
    throw "CSV not found: $vmListFile"
}

$vmList = Import-Csv $vmListFile

Write-Host "Logging into Azure..."
Connect-AzAccount

$subscription = (Get-AzContext).Subscription.Id

$scriptBlock = {

    param($VMName,$RG,$SubscriptionId)

    try {

        Import-Module Az.Accounts
        Import-Module Az.Compute

        # Login again inside each job
        Connect-AzAccount -Identity -ErrorAction Stop | Out-Null

        Set-AzContext -SubscriptionId $SubscriptionId | Out-Null

        Restart-AzVM `
            -Name $VMName `
            -ResourceGroupName $RG `
            -NoWait `
            -ErrorAction Stop

        [PSCustomObject]@{
            VMName = $VMName
            ResourceGroup = $RG
            Status = "Success"
            Message = "Restart initiated"
        }

    }
    catch {

        [PSCustomObject]@{
            VMName = $VMName
            ResourceGroup = $RG
            Status = "Failed"
            Message = $_.Exception.Message
        }

    }

}

$jobs = @()
$results = @()

foreach($vm in $vmList){

    while(($jobs | Where State -eq Running).Count -ge $maxJobs){

        $finished = Wait-Job -Job $jobs -Any

        $results += Receive-Job $finished

        Remove-Job $finished

        $jobs = $jobs | Where State -eq Running

    }

    Write-Host "Queueing $($vm.VMName)"

    $jobs += Start-Job `
        -ScriptBlock $scriptBlock `
        -ArgumentList $vm.VMName,$vm.ResourceGroup,$subscription

}

Wait-Job $jobs | Out-Null

foreach($job in $jobs){

    $results += Receive-Job $job

    Remove-Job $job

}

$results | Export-Csv $reportPath -NoTypeInformation

Write-Host ""
Write-Host "Completed"
Write-Host "Success :" (($results | Where Status -eq Success).Count)
Write-Host "Failed  :" (($results | Where Status -eq Failed).Count)
Write-Host "Report  : $reportPath"
