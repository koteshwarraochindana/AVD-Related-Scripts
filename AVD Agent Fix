#Install


# --- CONFIGURATION ---
$Token = "TOKEN_HERE"
$SourceFolder = "\\dfw1mspif017\Public\Ally_AVD\Agents" 
$LocalPath = "C:\Temp\AVDInstall"

# File names from your discovery
$SxSFile    = "SxSStack-1.0.2507.25770.msi"
$AgentFile  = "Microsoft.RDInfra.RDAgent.Installer-x64-1.0.12684.400.msi"
$LoaderFile = "Microsoft.RDInfra.RDAgentBootLoader.Installer-x64-1.0.11388.1600.msi"

if (!(Test-Path $LocalPath)) { New-Item -ItemType Directory -Path $LocalPath -Force }

# 1. COPY FROM SHARE
Write-Host "Copying installers from $SourceFolder..." -ForegroundColor Cyan
Copy-Item -Path "$SourceFolder\$SxSFile" -Destination $LocalPath -Force
Copy-Item -Path "$SourceFolder\$AgentFile" -Destination $LocalPath -Force
Copy-Item -Path "$SourceFolder\$LoaderFile" -Destination $LocalPath -Force

# 2. INSTALL IN PRECISE ORDER
Write-Host "Installing SxS Stack (Fixes Listener)..." -ForegroundColor Yellow
Start-Process msiexec.exe -ArgumentList "/i `"$LocalPath\$SxSFile`" /qn /norestart" -Wait

Write-Host "Installing Agent (Handles Registration)..." -ForegroundColor Yellow
Start-Process msiexec.exe -ArgumentList "/i `"$LocalPath\$AgentFile`" /qn /norestart REGISTRATIONTOKEN=$Token" -Wait

Write-Host "Installing Bootloader..." -ForegroundColor Yellow
Start-Process msiexec.exe -ArgumentList "/i `"$LocalPath\$LoaderFile`" /qn /norestart" -Wait

# 3. FINAL REBOOT
Write-Host "INSTALL SUCCESSFUL. Final reboot to start the AVD stack..." -ForegroundColor Green
Restart-Computer -Force
