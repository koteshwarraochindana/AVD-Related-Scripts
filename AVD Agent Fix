#Un-Install

# 1. Stop AVD-related services
Write-Host "Stopping AVD Services..." -ForegroundColor Yellow
$services = "RDAgentBootLoader", "RdAgent", "Remote Desktop Services Infrastructure Agent"
foreach ($service in $services) {
    if (Get-Service $service -ErrorAction SilentlyContinue) {
        Stop-Service $service -Force -ErrorAction SilentlyContinue
    }
}

# 2. Uninstall AVD Components via MSIExec
Write-Host "Uninstalling AVD Agent and Bootloader..." -ForegroundColor Yellow
$apps = Get-WmiObject -Class Win32_Product | Where-Object { 
    $_.Name -like "*Remote Desktop Services Infrastructure Agent*" -or 
    $_.Name -like "*Remote Desktop Agent Boot Loader*" -or
    $_.Name -like "*Remote Desktop Services SxS Network Stack*"
}

foreach ($app in $apps) {
    Write-Host "Removing: $($app.Name)"
    msiexec.exe /x $($app.IdentifyingNumber) /qn /norestart
}

# 3. Clean up leftover Registry Keys
Write-Host "Cleaning Registry..." -ForegroundColor Yellow
$registryPaths = @(
    "HKLM:\SOFTWARE\Microsoft\RDInfraAgent",
    "HKLM:\SOFTWARE\Microsoft\RDAgentBootLoader",
    "HKLM:\SOFTWARE\Classes\Installer\Products\*" # Caution: Only if specific AVD GUIDs are known
)

foreach ($path in $registryPaths) {
    if (Test-Path $path) {
        Remove-Item -Path $path -Recurse -Force -ErrorAction SilentlyContinue
    }
}

# 4. Clean up Installation Folders
Write-Host "Deleting leftover files..." -ForegroundColor Yellow
$folders = @("C:\Program Files\Microsoft RDInfra", "C:\ProgramData\Microsoft\RDInfra")
foreach ($folder in $folders) {
    if (Test-Path $folder) {
        Remove-Item -Path $folder -Recurse -Force -ErrorAction SilentlyContinue
    }
}

Write-Host "Uninstall Complete. Please restart the VM before reinstalling the agents." -ForegroundColor Green
